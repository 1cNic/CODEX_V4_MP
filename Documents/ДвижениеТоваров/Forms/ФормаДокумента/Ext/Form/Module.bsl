&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока.Характеристика = ПолучитьХарактеристикуПоУмолчаниюНаСервере(ТекущаяСтрока.Номенклатура);
КонецПроцедуры

&НаСервере
Функция ПолучитьХарактеристикуПоУмолчаниюНаСервере(Номенклатура)
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат ПолучитьПустуюХарактеристикуНаСервере();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Характеристики.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Характеристики КАК Характеристики
	|ГДЕ
	|	Характеристики.Владелец = &Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	Характеристики.Код";
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат ПолучитьПустуюХарактеристикуНаСервере();
КонецФункции

&НаСервере
Функция ПолучитьПустуюХарактеристикуНаСервере()
	Возврат Справочники.Характеристики.ПустаяСсылка();
КонецФункции
