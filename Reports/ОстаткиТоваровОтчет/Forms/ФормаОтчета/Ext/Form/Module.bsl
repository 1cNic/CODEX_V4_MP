&НаКлиенте
Процедура Сформировать(Команда)
	СформироватьОтчетНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ДатаОкончания = КонецДня(ТекущаяДата());
	ДатаНачала = НачалоДня(ДобавитьМесяц(ДатаОкончания, -1));
	ЗначениеВРеквизитФормы(ИнициализироватьТаблицуРезультата(), "РезультатОтчета");
КонецПроцедуры

&НаСервере
Процедура СформироватьОтчетНаСервере()
	ТаблицаРезультата = ПолучитьДанныеОтчета();
	ЗначениеВРеквизитФормы(ТаблицаРезультата, "РезультатОтчета");
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеОтчета()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(Остатки.Номенклатура) КАК Номенклатура,
	|	ПРЕДСТАВЛЕНИЕ(Остатки.Характеристика) КАК Характеристика,
	|	Остатки.КоличествоНачальныйОстаток КАК НачальныйОстаток,
	|	Остатки.КоличествоПриход КАК Приход,
	|	Остатки.КоличествоРасход КАК Расход,
	|	Остатки.КоличествоКонечныйОстаток КАК КонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТоваров.ОстаткиИОбороты(&ДатаНачала, &ДатаОкончания, , ) КАК Остатки";
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
	
	ТаблицаРезультата = Запрос.Выполнить().Выгрузить();
	ТаблицаРезультата.Сортировать("Номенклатура, Характеристика");
	Возврат ТаблицаРезультата;
КонецФункции

&НаСервереБезКонтекста
Функция ИнициализироватьТаблицуРезультата()
	ТаблицаРезультата = Новый ТаблицаЗначений;
	ТаблицаРезультата.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(150)));
	ТаблицаРезультата.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(150)));
	ТаблицаРезультата.Колонки.Добавить("НачальныйОстаток", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	ТаблицаРезультата.Колонки.Добавить("Приход", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	ТаблицаРезультата.Колонки.Добавить("Расход", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	ТаблицаРезультата.Колонки.Добавить("КонечныйОстаток", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	Возврат ТаблицаРезультата;
КонецФункции
