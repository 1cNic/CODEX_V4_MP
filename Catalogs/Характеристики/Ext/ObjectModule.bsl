Процедура ПередЗаписью(Отказ)

	ОбновитьНаименование();

КонецПроцедуры

Процедура ОбновитьНаименование()

	ЧастиНаименования = Новый Массив;

	Если ЗначениеЗаполнено(Владелец) Тогда
		ЧастиНаименования.Добавить(СокрЛП(Строка(Владелец)));
	КонецЕсли;

	Если ЗначениеЗаполнено(Цвет) Тогда
		ЧастиНаименования.Добавить(СокрЛП(Цвет));
	КонецЕсли;

	Если ЗначениеЗаполнено(Размер) Тогда
		ЧастиНаименования.Добавить(СокрЛП(Размер));
	КонецЕсли;

	Если ЧастиНаименования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Наименование = СтрСоединить(ЧастиНаименования, " - ");

КонецПроцедуры
